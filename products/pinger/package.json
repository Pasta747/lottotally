{
  "name": "pinger",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate -w packages/db",
    "dev": "npm run dev -w apps/web",
    "build": "npm run db:generate -w packages/db && npm run build -w apps/web",
    "vercel-build": "npm run db:generate -w packages/db && npm run build -w apps/web",
    "lint": "npm run lint -w apps/web",
    "typecheck": "npm run typecheck -w apps/web",
    "test": "npm run test -w apps/web",
    "db:generate": "npm run db:generate -w packages/db",
    "db:migrate": "npm run db:migrate -w packages/db",
    "db:push": "npm run db:push -w packages/db"
  },
  "overrides": {
    "prisma": "6.19.2",
    "@prisma/client": "6.19.2"
  }
}
